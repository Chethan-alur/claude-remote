<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Dark base so the launch window matches the dark Compose UI (no white flash). -->
    <style name="Theme.ClaudeRemote" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/brand_bg</item>
        <item name="android:statusBarColor">@color/brand_bg</item>
        <item name="android:navigationBarColor">@color/brand_bg</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>
</resources>
